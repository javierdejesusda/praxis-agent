# Praxis Agent — Environment Variables
# Copy this file to .env and fill in your keys.

# OpenAI API (required for LLM analyst; deterministic fallback works without it)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2

# Sepolia testnet (required for on-chain attestation)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_PRIVATE_KEY=0x...

# PRISM market data enrichment (optional)
PRISM_API_KEY=prism_sk_...

# Financial Modeling Prep (required for historical price data)
FMP_API_KEY=your_fmp_api_key_here
